# GitHub Personal Access Token (classic)
# Нужные scopes: repo, workflow
# Создать: https://github.com/settings/tokens
ACCESS_TOKEN=

# Твой GitHub username (для user mode) или org name (для org mode)
GITHUB_USERNAME=

# Режим регистрации runner'а:
#   user — недокументированный user-level (один runner для всех личных репо)
#   org  — официальный org-level (если user mode перестанет работать)
RUNNER_SCOPE=user

# Имя runner'а (отображается в GitHub UI)
RUNNER_NAME=my-runner

# Лейблы через запятую (используются в runs-on в workflow)
# Примеры: linux,x64,high-power | linux,x64,low-power | linux,arm64,laptop
LABELS=self-hosted,linux,x64

# Опционально: имя org (только для RUNNER_SCOPE=org, если отличается от GITHUB_USERNAME)
# ORG_NAME=
